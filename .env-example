# Copy this file to .env and fill in real values locally.
# .env is git-ignored; never commit real secrets. See docs/tasks.md Appendix A.

# Gmail API (OAuth 2.0) — set up in Chapter 9 / Stage 7
GMAIL_CREDENTIALS_PATH=credentials.json
GMAIL_TOKEN_PATH=token.json

# LLM provider (Chapter 6 / Stage 4) — only needed for claude_api / claude_cli trash-talk modes
ANTHROPIC_API_KEY=
